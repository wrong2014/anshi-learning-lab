# Provider keys are read from the environment named in providers.example.json.
PLF_PLANNER_API_KEY=
PLF_EXECUTOR_A_API_KEY=
PLF_EXECUTOR_B_API_KEY=
PLF_SUPERVISOR_API_KEY=

# Unified retrieval: leave the key empty until an Aliyun production index is built.
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1024
# Optional English task instruction; keep empty until A/B evaluation proves an improvement.
DASHSCOPE_EMBEDDING_INSTRUCT=
